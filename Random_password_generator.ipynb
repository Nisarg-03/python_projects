   "source": [
    "import random\n",
    "import string\n",
    "length = int(input(\"Enter password length :\"))\n",
    "char = string.ascii_letters + string.digits + string.punctuation\n",
    "password = \"\"\n",
    "\n",
    "for i in range(length):\n",
    "    password += random.choice(char)\n",
    "\n",
    "print(\"Generated password :\",password)"
   ]
  }
